{
  "name": "smartlink",
  "version": "0.1.2",
  "description": "Generate and install shared AI tool resources from one cross-platform Node.js CLI",
  "type": "module",
  "bin": {
    "smartlink": "./smartlink.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "setup": "node ./smartlink.js setup",
    "generate": "node ./smartlink.js generate",
    "sync": "node ./smartlink.js sync",
    "doctor": "node ./smartlink.js doctor"
  },
  "keywords": [
    "cli",
    "cross-platform",
    "agents",
    "prompts",
    "mcp"
  ],
  "license": "MIT"
}
