{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"require(require('path').join(require('os').homedir(), '.claude', 'hooks', 'load-agents-md.js'))\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"require(require('path').join(require('os').homedir(), '.claude', 'hooks', 'inject-init-override.js'))\""
          }
        ]
      }
    ]
  }
}
